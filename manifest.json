{
  "manifest_version": 3,
  "name": "Sling Shift Catcher",
  "version": "0.3.0",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://app.getsling.com/*", "https://ntfy.sh/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Sling Shift Catcher",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://app.getsling.com/messages/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
